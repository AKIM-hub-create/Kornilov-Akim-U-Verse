<p local-id=3D"9c2c5e8f3e9b">=D0=9F=D0=BE=D0=BB=D1=83=D1=87=D0=B8=D1=82=D1=
=8C =D1=81=D0=BF=D0=B8=D1=81=D0=BE=D0=BA =D0=BA=D1=83=D1=80=D1=81=D0=BE=D0=
=B2 =D1=81 =D0=BF=D0=B0=D0=B3=D0=B8=D0=BD=D0=B0=D1=86=D0=B8=D0=B5=D0=B9 =D0=
=B8 =D0=BD=D0=B5=D0=BE=D0=B1=D1=85=D0=BE=D0=B4=D0=B8=D0=BC=D1=8B=D0=BC=D0=
=B8 =D1=81=D0=B2=D1=8F=D0=B7=D0=B0=D0=BD=D0=BD=D1=8B=D0=BC=D0=B8 =D0=B4=D0=
=B0=D0=BD=D0=BD=D1=8B=D0=BC=D0=B8:</p></li>
</ol>
<div class=3D"code panel pdl" style=3D"border-width: 1px;">
<div class=3D"codeContent panelContent pdl">
<pre class=3D"syntaxhighlighter-pre" data-syntaxhighlighter-params=3D"brush=
: sql; gutter: false; theme: Confluence" data-theme=3D"Confluence">SELECT
  c.id,
  c.name,
  c.description,
  c.duration,
  c.category_id,
  cat.name AS category_name,
  c.status_id,
  st.name AS status_name,
  c.employee_id,
  emp.first_name,
  emp.last_name,
  emp.middle_name,
  c.created_at,
  c.published_at
FROM course c
LEFT JOIN category cat ON c.category_id =3D cat.id
LEFT JOIN status st ON c.status_id =3D st.id
LEFT JOIN employees emp ON c.employee_id =3D emp.id
WHERE c.is_active =3D true AND c.published_at IS NOT NULL
ORDER BY c.published_at DESC
LIMIT {{limit}} OFFSET {{(page - 1) * limit}};</pre>
</div>
</div>
